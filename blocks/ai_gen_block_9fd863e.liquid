{% doc %}
  @prompt
    Create a product page section that displays supplement/vitamin product details from metafields in the custom namespace. Handle both rich_text_field and multi_line_text_field types correctly — use the metafield_tag filter or render the value properly for rich text fields (not raw JSON). Show these metafields when they have data: supplement_facts (rich text), other_ingredients (rich text), specifications (multi-line text), directions (multi-line text), key_benefits (multi-line text). Display in a clean accordion layout with navy blue (#2E3192) headers and light gray background. Hide any section where the metafield is empty. Clinical, pharmacy-grade typography.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-supplement-details-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-supplement-details__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing }}px;
    letter-spacing: 0.5px;
  }

  .ai-supplement-details__accordion-{{ ai_gen_id }} {
    border-top: 1px solid {{ block.settings.divider_color }};
  }

  .ai-supplement-details__item-{{ ai_gen_id }} {
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-supplement-details__header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.2s ease;
  }

  .ai-supplement-details__header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.header_hover_color }};
  }

  .ai-supplement-details__header-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.header_size }}px;
    font-weight: 600;
    color: {{ block.settings.header_color }};
    margin: 0;
    letter-spacing: 0.3px;
  }

  .ai-supplement-details__icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    transition: transform 0.3s ease;
    color: {{ block.settings.header_color }};
  }

  .ai-supplement-details__header-{{ ai_gen_id }}[aria-expanded="true"] .ai-supplement-details__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-supplement-details__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-supplement-details__content-{{ ai_gen_id }}.active {
    max-height: 2000px;
  }

  .ai-supplement-details__content-inner-{{ ai_gen_id }} {
    padding: 0 0 {{ block.settings.item_padding }}px;
    color: {{ block.settings.content_color }};
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.6;
  }

  .ai-supplement-details__content-inner-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-supplement-details__content-inner-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-supplement-details__content-inner-{{ ai_gen_id }} ul,
  .ai-supplement-details__content-inner-{{ ai_gen_id }} ol {
    margin: 0 0 12px;
    padding-left: 20px;
  }

  .ai-supplement-details__content-inner-{{ ai_gen_id }} li {
    margin-bottom: 6px;
  }

  .ai-supplement-details__multiline-{{ ai_gen_id }} {
    white-space: pre-wrap;
  }

  @media screen and (max-width: 749px) {
    .ai-supplement-details-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.section_padding | times: 0.7 }}px;
    }

    .ai-supplement-details__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-supplement-details__header-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.header_size | times: 0.9 }}px;
    }

    .ai-supplement-details__content-inner-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_size | times: 0.95 }}px;
    }
  }
{% endstyle %}

<supplement-details-{{ ai_gen_id }} class="ai-supplement-details-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <h2 class="ai-supplement-details__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
  {% endif %}

  <div class="ai-supplement-details__accordion-{{ ai_gen_id }}">
    {% liquid
      assign supplement_facts = product.metafields.custom.supplement_facts
      assign other_ingredients = product.metafields.custom.other_ingredients
      assign specifications = product.metafields.custom.specifications
      assign directions = product.metafields.custom.directions
      assign key_benefits = product.metafields.custom.key_benefits
    %}

    {% if supplement_facts != blank %}
      <div class="ai-supplement-details__item-{{ ai_gen_id }}">
        <button
          class="ai-supplement-details__header-{{ ai_gen_id }}"
          aria-expanded="false"
          data-accordion-trigger
        >
          <h3 class="ai-supplement-details__header-title-{{ ai_gen_id }}">Supplement Facts</h3>
          <svg class="ai-supplement-details__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="ai-supplement-details__content-{{ ai_gen_id }}" data-accordion-content>
          <div class="ai-supplement-details__content-inner-{{ ai_gen_id }}">
            {{ supplement_facts | metafield_tag }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if other_ingredients != blank %}
      <div class="ai-supplement-details__item-{{ ai_gen_id }}">
        <button
          class="ai-supplement-details__header-{{ ai_gen_id }}"
          aria-expanded="false"
          data-accordion-trigger
        >
          <h3 class="ai-supplement-details__header-title-{{ ai_gen_id }}">Other Ingredients</h3>
          <svg class="ai-supplement-details__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="ai-supplement-details__content-{{ ai_gen_id }}" data-accordion-content>
          <div class="ai-supplement-details__content-inner-{{ ai_gen_id }}">
            {{ other_ingredients | metafield_tag }}
          </div>
        </div>
      </div>
    {% endif %}

    {% if key_benefits != blank %}
      <div class="ai-supplement-details__item-{{ ai_gen_id }}">
        <button
          class="ai-supplement-details__header-{{ ai_gen_id }}"
          aria-expanded="false"
          data-accordion-trigger
        >
          <h3 class="ai-supplement-details__header-title-{{ ai_gen_id }}">Key Benefits</h3>
          <svg class="ai-supplement-details__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="ai-supplement-details__content-{{ ai_gen_id }}" data-accordion-content>
          <div class="ai-supplement-details__content-inner-{{ ai_gen_id }}">
            <div class="ai-supplement-details__multiline-{{ ai_gen_id }}">{{ key_benefits.value }}</div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if directions != blank %}
      <div class="ai-supplement-details__item-{{ ai_gen_id }}">
        <button
          class="ai-supplement-details__header-{{ ai_gen_id }}"
          aria-expanded="false"
          data-accordion-trigger
        >
          <h3 class="ai-supplement-details__header-title-{{ ai_gen_id }}">Directions</h3>
          <svg class="ai-supplement-details__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="ai-supplement-details__content-{{ ai_gen_id }}" data-accordion-content>
          <div class="ai-supplement-details__content-inner-{{ ai_gen_id }}">
            <div class="ai-supplement-details__multiline-{{ ai_gen_id }}">{{ directions.value }}</div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if specifications != blank %}
      <div class="ai-supplement-details__item-{{ ai_gen_id }}">
        <button
          class="ai-supplement-details__header-{{ ai_gen_id }}"
          aria-expanded="false"
          data-accordion-trigger
        >
          <h3 class="ai-supplement-details__header-title-{{ ai_gen_id }}">Specifications</h3>
          <svg class="ai-supplement-details__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="ai-supplement-details__content-{{ ai_gen_id }}" data-accordion-content>
          <div class="ai-supplement-details__content-inner-{{ ai_gen_id }}">
            <div class="ai-supplement-details__multiline-{{ ai_gen_id }}">{{ specifications.value }}</div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</supplement-details-{{ ai_gen_id }}>

<script>
  (function() {
    class SupplementDetails{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.triggers = this.querySelectorAll('[data-accordion-trigger]');
        this.setupAccordion();
      }

      setupAccordion() {
        this.triggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            const content = trigger.nextElementSibling;
            const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

            trigger.setAttribute('aria-expanded', !isExpanded);
            content.classList.toggle('active');
          });
        });
      }
    }

    customElements.define('supplement-details-{{ ai_gen_id }}', SupplementDetails{{ ai_gen_id }});
  })();
</script>

