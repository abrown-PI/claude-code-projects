      "default": 16
    },
    {
      "type": "range",
      "id": "content_size",
      "label": "Content size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f9f9"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title",
      "default": "#2E3192"
    },
    {
      "type": "color",
      "id": "header_color",
      "label": "Accordion header",
      "default": "#2E3192"
    },
    {
      "type": "color",
      "id": "header_hover_color",
      "label": "Header hover background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "content_color",
      "label": "Content text",
      "default": "#323234"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider",
      "default": "#e0e0e0"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item padding",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Supplement details"
    }
  ]
}
{% endschema %}
