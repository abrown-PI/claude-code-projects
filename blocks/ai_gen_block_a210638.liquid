{% doc %}
  @prompt
    Edit the existing Supplement Facts block (section ID: template--20701053616355__17769050134a31ce53, block ID: template--20701053616355__17769050134a31ce53__ai_gen_block_c94f0c9_tD9pV9). Replace the entire block with this complete layout: SECTION 1 - Specs Header Row: Display three items side by side in a row with bold labels above values: "Package Size" from custom.package_size, "Serving Size" from custom.serving_size, "Servings Per Container" from custom.serving_per_container. SECTION 2 - Supplement Facts Table: Bordered FDA-style table with navy blue (#2E3192) header row. Headers: "Ingredient" and "Amount Per Serving". Read custom.supplement_facts (multi-line text), split each line on " - " dash to get ingredient name and amount, render as table rows. SECTION 3 - Accordions below the table, navy blue (#2E3192) bold headers, chevron toggle, light gray background, each hidden if metafield is empty: "Key Benefits" from custom.key_benefits split on newline rendered as ul/li bullet list. "Directions" from custom.directions as plain text. "Other Ingredients" from custom.other_ingredients as plain text. "Does Not Contain" from custom.does_not_contain as plain text. "Caution and Storage" combining custom.caution and custom.storage as two labeled lines.
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-supplement-facts-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 20px;
    background-color: #ffffff;
  }

  .ai-supplement-specs-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 30px;
    flex-wrap: wrap;
  }

  .ai-supplement-spec-item-{{ ai_gen_id }} {
    flex: 1;
    min-width: 150px;
    text-align: center;
  }

  .ai-supplement-spec-label-{{ ai_gen_id }} {
    font-weight: 700;
    font-size: 14px;
    color: #323234;
    margin-bottom: 5px;
    text-transform: uppercase;
  }

  .ai-supplement-spec-value-{{ ai_gen_id }} {
    font-size: 16px;
    color: #323234;
  }

  .ai-supplement-table-{{ ai_gen_id }} {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 30px;
    border: 2px solid #2E3192;
  }

  .ai-supplement-table-{{ ai_gen_id }} thead {
    background-color: #2E3192;
    color: #ffffff;
  }

  .ai-supplement-table-{{ ai_gen_id }} th {
    padding: 12px;
    text-align: left;
    font-weight: 700;
    font-size: 14px;
  }

  .ai-supplement-table-{{ ai_gen_id }} td {
    padding: 10px 12px;
    border-bottom: 1px solid #e0e0e0;
    font-size: 14px;
    color: #323234;
    vertical-align: top;
  }

  .ai-supplement-table-{{ ai_gen_id }} tbody tr:last-child td {
    border-bottom: none;
  }

  .ai-supplement-accordion-{{ ai_gen_id }} {
    margin-bottom: 10px;
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    overflow: hidden;
  }

  .ai-supplement-accordion-header-{{ ai_gen_id }} {
    width: 100%;
    padding: 15px 20px;
    background-color: #f9f9f9;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: 700;
    font-size: 16px;
    color: #2E3192;
  }

  .ai-supplement-accordion-header-{{ ai_gen_id }}:hover {
    background-color: #f0f0f0;
  }

  .ai-supplement-accordion-chevron-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
  }

  .ai-supplement-accordion-chevron-{{ ai_gen_id }}.active {
    transform: rotate(180deg);
  }

  .ai-supplement-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background-color: #ffffff;
  }

  .ai-supplement-accordion-content-{{ ai_gen_id }}.active {
    max-height: 1000px;
  }

  .ai-supplement-accordion-inner-{{ ai_gen_id }} {
    padding: 15px 20px;
    font-size: 14px;
    line-height: 1.6;
    color: #323234;
  }

  .ai-supplement-accordion-inner-{{ ai_gen_id }} ul {
    margin: 0;
    padding-left: 20px;
  }

  .ai-supplement-accordion-inner-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-supplement-caution-storage-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .ai-supplement-caution-storage-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
  }

  .ai-supplement-caution-storage-label-{{ ai_gen_id }} {
    font-weight: 700;
    margin-bottom: 5px;
  }

  @media screen and (max-width: 749px) {
    .ai-supplement-specs-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 15px;
    }

    .ai-supplement-spec-item-{{ ai_gen_id }} {
      min-width: 100%;
    }
  }
{% endstyle %}

<supplement-facts-{{ ai_gen_id }} class="ai-supplement-facts-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if product.metafields.custom.package_size != blank or product.metafields.custom.serving_size != blank or product.metafields.custom.serving_per_container != blank %}
    <div class="ai-supplement-specs-{{ ai_gen_id }}">
      {% if product.metafields.custom.package_size != blank %}
        <div class="ai-supplement-spec-item-{{ ai_gen_id }}">
          <div class="ai-supplement-spec-label-{{ ai_gen_id }}">Package Size</div>
          <div class="ai-supplement-spec-value-{{ ai_gen_id }}">{{ product.metafields.custom.package_size }}</div>
        </div>
      {% endif %}

      {% if product.metafields.custom.serving_size != blank %}
        <div class="ai-supplement-spec-item-{{ ai_gen_id }}">
          <div class="ai-supplement-spec-label-{{ ai_gen_id }}">Serving Size</div>
          <div class="ai-supplement-spec-value-{{ ai_gen_id }}">{{ product.metafields.custom.serving_size }}</div>
        </div>
      {% endif %}

      {% if product.metafields.custom.serving_per_container != blank %}
        <div class="ai-supplement-spec-item-{{ ai_gen_id }}">
          <div class="ai-supplement-spec-label-{{ ai_gen_id }}">Servings Per Container</div>
          <div class="ai-supplement-spec-value-{{ ai_gen_id }}">{{ product.metafields.custom.serving_per_container }}</div>
        </div>
      {% endif %}
    </div>
  {% endif %}

  {% if product.metafields.custom.supplement_facts != blank %}
    <table class="ai-supplement-table-{{ ai_gen_id }}">
      <thead>
        <tr>
          <th>Ingredient</th>
          <th>Amount Per Serving</th>
        </tr>
      </thead>
      <tbody>
        {% assign facts_raw = product.metafields.custom.supplement_facts | newline_to_br | replace: '<br />', '<br>' | split: '<br>' %}
        {% for line in facts_raw %}
          {% assign trimmed_line = line | strip | strip_html %}
          {% if trimmed_line != blank %}
            {% assign parts = trimmed_line | split: ' — ' %}
            {% if parts.size >= 2 %}
              <tr>
                <td>{{ parts[0] | strip }}</td>
                <td>{{ parts[1] | strip }}</td>
              </tr>
            {% else %}
              {% assign parts2 = trimmed_line | split: ' - ' %}
              {% if parts2.size >= 2 %}
                <tr>
                  <td>{{ parts2[0] | strip }}</td>
                  <td>{{ parts2[1] | strip }}</td>
                </tr>
              {% else %}
                <tr>
                  <td colspan="2" style="font-style: italic; color: #666;">{{ trimmed_line }}</td>
                </tr>
              {% endif %}
            {% endif %}
          {% endif %}
        {% endfor %}
      </tbody>
    </table>
  {% endif %}

  {% if product.metafields.custom.key_benefits != blank %}
    <div class="ai-supplement-accordion-{{ ai_gen_id }}">
      <button
        class="ai-supplement-accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        data-accordion-trigger
      >
        <span>Key Benefits</span>
        <svg
          class="ai-supplement-accordion-chevron-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#2E3192"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-supplement-accordion-content-{{ ai_gen_id }}">
        <div class="ai-supplement-accordion-inner-{{ ai_gen_id }}">
          <ul>
            {% assign benefits_raw = product.metafields.custom.key_benefits | newline_to_br | replace: '<br />', '<br>' | split: '<br>' %}
            {% for benefit in benefits_raw %}
              {% assign trimmed_benefit = benefit | strip | strip_html %}
              {% if trimmed_benefit != blank %}
                <li>{{ trimmed_benefit }}</li>
              {% endif %}
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  {% endif %}

  {% if product.metafields.custom.directions != blank %}
    <div class="ai-supplement-accordion-{{ ai_gen_id }}">
      <button
        class="ai-supplement-accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        data-accordion-trigger
      >
        <span>Directions</span>
        <svg
          class="ai-supplement-accordion-chevron-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#2E3192"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-supplement-accordion-content-{{ ai_gen_id }}">
        <div class="ai-supplement-accordion-inner-{{ ai_gen_id }}">
          {{ product.metafields.custom.directions }}
        </div>
      </div>
    </div>
  {% endif %}

  {% if product.metafields.custom.other_ingredients != blank %}
    <div class="ai-supplement-accordion-{{ ai_gen_id }}">
      <button
        class="ai-supplement-accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        data-accordion-trigger
      >
        <span>Other Ingredients</span>
        <svg
          class="ai-supplement-accordion-chevron-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#2E3192"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-supplement-accordion-content-{{ ai_gen_id }}">
        <div class="ai-supplement-accordion-inner-{{ ai_gen_id }}">
          {{ product.metafields.custom.other_ingredients }}
        </div>
      </div>
    </div>
  {% endif %}

  {% if product.metafields.custom.does_not_contain != blank %}
    <div class="ai-supplement-accordion-{{ ai_gen_id }}">
      <button
        class="ai-supplement-accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        data-accordion-trigger
      >
        <span>Does Not Contain</span>
        <svg
          class="ai-supplement-accordion-chevron-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#2E3192"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-supplement-accordion-content-{{ ai_gen_id }}">
        <div class="ai-supplement-accordion-inner-{{ ai_gen_id }}">
          {{ product.metafields.custom.does_not_contain }}
        </div>
      </div>
    </div>
  {% endif %}

  {% if product.metafields.custom.caution != blank or product.metafields.custom.storage != blank %}
    <div class="ai-supplement-accordion-{{ ai_gen_id }}">
      <button
        class="ai-supplement-accordion-header-{{ ai_gen_id }}"
        aria-expanded="false"
        data-accordion-trigger
      >
        <span>Caution and Storage</span>
        <svg
          class="ai-supplement-accordion-chevron-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#2E3192"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-supplement-accordion-content-{{ ai_gen_id }}">
        <div class="ai-supplement-accordion-inner-{{ ai_gen_id }}">
          <div class="ai-supplement-caution-storage-{{ ai_gen_id }}">
            {% if product.metafields.custom.caution != blank %}
              <div class="ai-supplement-caution-storage-item-{{ ai_gen_id }}">
                <div class="ai-supplement-caution-storage-label-{{ ai_gen_id }}">Caution:</div>
                <div>{{ product.metafields.custom.caution }}</div>
              </div>
            {% endif %}
            {% if product.metafields.custom.storage != blank %}
              <div class="ai-supplement-caution-storage-item-{{ ai_gen_id }}">
                <div class="ai-supplement-caution-storage-label-{{ ai_gen_id }}">Storage:</div>
                <div>{{ product.metafields.custom.storage }}</div>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</supplement-facts-{{ ai_gen_id }}>

<script>
  (function() {
    class SupplementFacts{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionTriggers = this.querySelectorAll('[data-accordion-trigger]');
        this.setupAccordions();
      }

      setupAccordions() {
        this.accordionTriggers.forEach((trigger) => {
          trigger.addEventListener('click', () => {
            const content = trigger.nextElementSibling;
            const chevron = trigger.querySelector('.ai-supplement-accordion-chevron-{{ ai_gen_id }}');
            const isActive = content.classList.contains('active');

            if (isActive) {
              content.classList.remove('active');
              chevron.classList.remove('active');
              trigger.setAttribute('aria-expanded', 'false');
            } else {
              content.classList.add('active');
              chevron.classList.add('active');
              trigger.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('supplement-facts-{{ ai_gen_id }}', SupplementFacts{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Supplement facts",
  "tag": null,
  "settings": [],
  "presets": [
    {
      "name": "Supplement facts"
    }
  ]
}
{% endschema %}