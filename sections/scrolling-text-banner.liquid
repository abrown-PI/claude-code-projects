  {%- style -%}
    .stb {
      position: relative;
      width: 100%;
      min-height: {{ section.settings.height }}vh;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .stb__bg {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
    }
    .stb__bg img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .stb__overlay {
      position: absolute;
      top: 0; left: 0; right: 0; bottom: 0;
      background: rgba(0,0,0,{{ section.settings.overlay_opacity }});
      z-index: 1;
    }
    .stb__scroll-track {
      position: absolute;
      left: 0; right: 0;
      display: flex;
      align-items: center;
      z-index: 2;
      overflow: hidden;
      pointer-events: none;
      {%- case section.settings.scroll_position -%}
        {%- when 'top' -%}
          top: 0; bottom: auto;
          padding-top: 3vh;
        {%- when 'middle' -%}
          top: 50%; bottom: auto;
          transform: translateY(-50%);
        {%- when 'bottom' -%}
          top: auto; bottom: 0;
          padding-bottom: 3vh;
      {%- endcase -%}
    }
    .stb__scroll-text {
      display: inline-flex;
      white-space: nowrap;
      animation: stb-scroll {{ section.settings.speed }}s linear infinite;
    }
    .stb__word {
      font-size: {{ section.settings.text_size }}px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: -0.02em;
      color: {{ section.settings.text_color }};
      opacity: {{ section.settings.text_opacity }};
      padding: 0 1.5rem;
      line-height: 1;
    }
    .stb__word--outline {
      color: transparent;
      -webkit-text-stroke: 2px {{ section.settings.text_color }};
    }
    @keyframes stb-scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .stb__cta {
      position: absolute;
      left: 0; right: 0;
      z-index: 3;
      {%- case section.settings.btn_v_position -%}
        {%- when 'top' -%}
          top: 3vh; bottom: auto;
        {%- when 'middle' -%}
          top: 50%; bottom: auto;
          transform: translateY(-50%);
        {%- when 'bottom' -%}
          top: auto; bottom: 3vh;
      {%- endcase -%}
      {%- case section.settings.btn_h_position -%}
        {%- when 'left' -%}
          text-align: left;
          padding-left: 5vw;
        {%- when 'center' -%}
          text-align: center;
        {%- when 'right' -%}
          text-align: right;
          padding-right: 5vw;
      {%- endcase -%}
    }
    .stb__btn {
      display: inline-block;
      background: {{ section.settings.btn_bg }};
      color: {{ section.settings.btn_text }};
      padding: 20px 60px;
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      text-decoration: none;
      border: 3px solid rgba(255,255,255,0.8);
      box-shadow: 0 6px 25px rgba(0,0,0,0.3), 0 0 0 1px rgba(255,255,255,0.2);
      transition: all 0.3s ease;
      pointer-events: all;
      backdrop-filter: blur(4px);
    }
    .stb__btn:hover {
      background: #ffffff;
      color: #1a1a1a;
      border-color: #ffffff;
      box-shadow: 0 8px 35px rgba(0,0,0,0.4);
      transform: translateY(-2px);
    }
    @media (max-width: 749px) {
      .stb__word {
        font-size: calc({{ section.settings.text_size }}px * 0.5);
      }
      .stb {
        min-height: 40vh;
      }
    }
  {%- endstyle -%}

  <section class="stb">
    <div class="stb__bg">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '800,1200,1600,2000' }}
      {%- else -%}
        <div style="background: linear-gradient(135deg, #f9f7f4 0%, #e8e4df 100%); width:100%; height:100%;"></div>
      {%- endif -%}
    </div>
    <div class="stb__overlay"></div>

    <div class="stb__scroll-track">
      <div class="stb__scroll-text">
        {%- for i in (1..20) -%}
          <span class="stb__word">{{ section.settings.scroll_text_1 }}</span>
          {%- if section.settings.outline_style -%}
            <span class="stb__word stb__word--outline">{{ section.settings.scroll_text_2 }}</span>
          {%- else -%}
            <span class="stb__word">{{ section.settings.scroll_text_2 }}</span>
          {%- endif -%}
          {%- if section.settings.scroll_text_3 != blank -%}
            <span class="stb__word">{{ section.settings.scroll_text_3 }}</span>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.btn_label != blank -%}
      <div class="stb__cta">
        <a href="{{ section.settings.btn_link }}" class="stb__btn">{{ section.settings.btn_label }}</a>
      </div>
    {%- endif -%}
  </section>

  {% schema %}
  {
    "name": "Scrolling Text Banner",
    "settings": [
      {
        "type": "header",
        "content": "Background"
      },
      {
        "type": "image_picker",
        "id": "image",
        "label": "Background image"
      },
      {
        "type": "range",
        "id": "height",
        "label": "Section height (vh)",
        "min": 30,
        "max": 80,
        "step": 5,
        "default": 50
      },
      {
        "type": "range",
        "id": "overlay_opacity",
        "label": "Overlay darkness",
        "min": 0,
        "max": 80,
        "step": 5,
        "default": 10,
        "info": "0 = no overlay, 80 = very dark"
      },
      {
        "type": "header",
        "content": "Scrolling Text"
      },
      {
        "type": "text",
        "id": "scroll_text_1",
        "label": "Text phrase 1",
        "default": "YOUR WELLNESS"
      },
      {
        "type": "text",
        "id": "scroll_text_2",
        "label": "Text phrase 2",
        "default": "OUR PRIORITY"
      },
      {
        "type": "text",
        "id": "scroll_text_3",
        "label": "Text phrase 3 (optional)",
        "default": "FEEL YOUR BEST"
      },
      {
        "type": "select",
        "id": "scroll_position",
        "label": "Scrolling text position",
        "options": [
          { "value": "top", "label": "Top" },
          { "value": "middle", "label": "Middle" },
          { "value": "bottom", "label": "Bottom" }
        ],
        "default": "top"
      },
      {
        "type": "range",
        "id": "speed",
        "label": "Scroll speed (seconds)",
        "min": 15,
        "max": 120,
        "step": 5,
        "default": 30,
        "info": "Higher = slower. Try 60-90 for a gentle scroll."
      },
      {
        "type": "range",
        "id": "text_size",
        "label": "Text size (px)",
        "min": 40,
        "max": 150,
        "step": 5,
        "default": 80
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Text color",
        "default": "#1a1a1a"
      },
      {
        "type": "range",
        "id": "text_opacity",
        "label": "Text opacity",
        "min": 10,
        "max": 100,
        "step": 5,
        "default": 30,
        "info": "Lower = more transparent"
      },
      {
        "type": "checkbox",
        "id": "outline_style",
        "label": "Alternate outline text style",
        "default": false,
        "info": "Makes every other phrase outlined instead of filled"
      },
      {
        "type": "header",
        "content": "Button"
      },
      {
        "type": "text",
        "id": "btn_label",
        "label": "Button label",
        "default": "BOOST ENERGY"
      },
      {
        "type": "url",
        "id": "btn_link",
        "label": "Button link"
      },
      {
        "type": "select",
        "id": "btn_v_position",
        "label": "Button vertical position",
        "options": [
          { "value": "top", "label": "Top" },
          { "value": "middle", "label": "Middle" },
          { "value": "bottom", "label": "Bottom" }
        ],
        "default": "bottom",
        "info": "Avoid matching the scrolling text position or they will overlap."
      },
      {
        "type": "select",
        "id": "btn_h_position",
        "label": "Button horizontal position",
        "options": [
          { "value": "left", "label": "Left" },
          { "value": "center", "label": "Center" },
          { "value": "right", "label": "Right" }
        ],
        "default": "center"
      },
      {
        "type": "color",
        "id": "btn_bg",
        "label": "Button color",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "btn_text",
        "label": "Button text color",
        "default": "#ffffff"
      }
    ],
    "presets": [
      {
        "name": "Scrolling Text Banner"
      }
    ]
  }
  {% endschema %}